{
  "name": "full-human-design-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:storybook-public": "rm -rf public/storybook storybook-static && mkdir -p public/storybook && storybook build -o storybook-static --disable-telemetry && cp -R storybook-static/. public/storybook",
    "build:vercel": "npm run build:storybook-public && next build",
    "start": "next start",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "serve-storybook": "serve storybook-static",
    "typecheck": "tsc --noEmit",
    "test": "vitest --project=storybook",
    "test-storybook": "vitest --project=storybook"
  },
  "dependencies": {
    "@fontsource/instrument-serif": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "playwright": "^1.59.1",
    "react-docgen-typescript": "^2.4.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
